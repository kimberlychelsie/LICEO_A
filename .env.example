# Copy to .env and fill in values. Do not commit .env.

# App
SECRET_KEY=your-long-random-secret-key-here
FLASK_ENV=development

# Database (used by the app: db.py)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=liceo_db
DB_USER=liceo_db
DB_PASSWORD=your-db-password

# Optional: single connection string (for scripts and some deploys e.g. Railway)
# Railway sets DATABASE_URL automatically; for local scripts you can set it instead of DB_*.
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Production (Railway sets these)
# RAILWAY_ENVIRONMENT=production
